# ============================
# إعدادات واتساب تكوين - البيئة
# ============================

# رابط قاعدة بيانات MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wats?retryWrites=true&w=majority

# مفتاح الجلسات (يجب أن يكون سرياً وطويلاً)
SESSION_SECRET=your_super_secret_session_key_here_change_me

# كلمة مرور الأدمن الافتراضية (تستخدم فقط عند أول تشغيل)
ADMIN_DEFAULT_PASSWORD=ChangeMe@2026!

# المنفذ
PORT=3000

# عدد أقصى للجلسات المتزامنة (اختياري)
MAX_CONCURRENT_SESSIONS=50

# النطاقات المسموحة للـ CORS (افصل بفاصلة) - اتركه فارغاً للسماح للكل
CORS_ORIGINS=
