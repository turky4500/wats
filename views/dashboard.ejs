<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحة المستخدم</title>
    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; }
        .header { display: flex; justify-content: space-between; align-items: center; background: white; padding: 15px 30px; border-radius: 8px; margin-bottom: 20px; }
        .btn { background: #25D366; color: white; padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer; text-decoration: none; }
        .grid { display: flex; gap: 20px; }
        .card { background: white; padding: 25px; border-radius: 8px; flex: 1; }
        #qr-container { text-align: center; }
        #qr-container img { width: 250px; border: 10px solid white; box-shadow: 0 0 10px rgba(0,0,0,0.1); border-radius: 10px; margin: 20px 0; }
        .chat-box { height: 250px; overflow-y: auto; background: #e5ddd5; padding: 15px; border-radius: 8px; margin-bottom: 15px; }
        .message { background: #dcf8c5; padding: 10px; border-radius: 8px; margin-bottom: 10px; display: inline-block; }
        input, textarea { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box; }
        .hidden { display: none; }
    </style>
</head>
<body>
    <div class="header">
        <h2>مرحباً، <%= user.username %> 👋</h2>
        <div>
            <% if (user.role === 'admin') { %><a href="/admin" class="btn" style="background:#075e54;">إدارة النظام</a><% } %>
            <a href="/logout" class="btn" style="background:#d32f2f;">تسجيل خروج</a>
        </div>
    </div>
    <div class="grid">
        <div class="card" id="connection-card">
            <h3 id="status-title">حالة الاتصال ⏳</h3>
            <div id="qr-container" class="hidden">
                <p>امسح رمز QR باستخدام واتساب:</p>
                <div id="qr-img"></div>
            </div>
            <div id="connected-container" class="hidden">
                <p style="color: #25D366; font-size: 18px; font-weight: bold;">✅ واتساب متصل بنجاح!</p>
                <hr>
                <h4>الربط الخارجي (API Token)</h4>
                <code style="background:#eee;padding:10px;display:block;"><%= user.apiToken %></code>
            </div>
        </div>
        <div class="card hidden" id="chat-card">
            <h3>إرسال الرسائل</h3>
            <div class="chat-box" id="messages"></div>
            <input type="text" id="phone" placeholder="الأرقام (مثال: 9665.., 9665..)" dir="ltr">
            <textarea id="msg" placeholder="اكتب رسالتك..." rows="3"></textarea>
            <button class="btn" id="send-btn" style="width: 100%;">إرسال</button>
        </div>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io({ query: { userId: "<%= user._id %>" } });
        socket.on('qr', (imgData) => {
            document.getElementById('status-title').innerText = "بانتظار المسح 📱";
            document.getElementById('qr-container').classList.remove('hidden');
            document.getElementById('connected-container').classList.add('hidden');
            document.getElementById('chat-card').classList.add('hidden');
            document.getElementById('qr-img').innerHTML = `<img src="${imgData}">`;
        });
        socket.on('ready', () => {
            document.getElementById('status-title').innerText = "متصل ✅";
            document.getElementById('qr-container').classList.add('hidden');
            document.getElementById('connected-container').classList.remove('hidden');
            document.getElementById('chat-card').classList.remove('hidden');
        });
        socket.on('message-sent', (data) => {
            const el = document.createElement('div');
            el.className = 'message';
            el.innerText = `أنت -> ${data.to}: ${data.body}`;
            document.getElementById('messages').appendChild(el);
        });
        socket.on('error', (err) => alert('خطأ: ' + err));
        document.getElementById('send-btn').onclick = () => {
            const to = document.getElementById('phone').value;
            const body = document.getElementById('msg').value;
            if (!to || !body) return alert("الرجاء إدخال البيانات");
            socket.emit('send-message', { to, body });
        };
    </script>
</body>
</html>
