<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>واتس اب تكوين - لوحة التحكم</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap');

        :root {
            --primary: #10b981;
            --primary-hover: #059669;
            --secondary: #3b82f6;
            --dark: #0f172a;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --bg-color: #f8fafc;
            --card-bg: #ffffff;
            --danger: #ef4444;
            --warning: #f59e0b;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--card-bg);
            padding: 20px 30px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
            margin-bottom: 25px;
        }

        .header h2 {
            margin: 0;
            font-weight: 800;
            color: var(--dark);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-family: 'Tajawal', sans-serif;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-hover); transform: translateY(-1px); }
        .btn-secondary { background: var(--warning); color: white; }
        .btn-danger { background: #fee2e2; color: var(--danger); }
        .btn-danger:hover { background: #fecaca; }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 25px;
        }

        .card {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
            border: 1px solid #e2e8f0;
        }

        .card h3 {
            margin-top: 0;
            color: var(--dark);
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        /* الإشعارات الذكية */
        #toast-container {
            position: fixed;
            bottom: 20px;
            left: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .toast {
            background: white;
            color: var(--text-main);
            padding: 15px 20px;
            border-radius: 8px;
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            font-weight: 500;
            animation: slideIn 0.3s ease forwards;
            display: flex;
            align-items: center;
            gap: 10px;
            border-right: 4px solid var(--primary);
        }
        .toast.error { border-right-color: var(--danger); }
        
        @keyframes slideIn {
            from { transform: translateX(-100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        input[type="text"], textarea {
            width: 100%;
            padding: 15px;
            margin-bottom: 15px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            font-family: 'Tajawal', sans-serif;
            font-size: 15px;
            box-sizing: border-box;
            background: #f8fafc;
            transition: border-color 0.2s;
        }
        input[type="text"]:focus, textarea:focus {
            outline: none;
            border-color: var(--primary);
            background: white;
        }

        .file-upload-box {
            border: 2px dashed #cbd5e1;
            padding: 20px;
            text-align: center;
            margin-bottom: 15px;
            border-radius: 8px;
            background: #f8fafc;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-muted);
            font-weight: 500;
        }
        .file-upload-box:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: #f0fdf4;
        }

        .chat-box {
            height: 250px;
            overflow-y: auto;
            background: #f8fafc;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
        }
        .message {
            background: var(--primary);
            color: white;
            padding: 10px 15px;
            border-radius: 8px;
            border-top-right-radius: 0;
            margin-bottom: 10px;
            display: inline-block;
            font-size: 14px;
        }

        .token-box {
            display: flex;
            background: #f8fafc;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 15px;
        }
        .token-box input {
            border: none;
            background: transparent;
            margin: 0;
            flex: 1;
            padding: 15px;
            font-family: monospace;
            color: var(--text-muted);
            outline: none;
        }
        .token-box button {
            margin: 0;
            border-radius: 0;
            height: auto;
        }

        pre {
            background: var(--dark);
            color: #f8f8f2;
            padding: 15px;
            border-radius: 8px;
            overflow-x: auto;
            font-family: monospace;
            direction: ltr;
            text-align: left;
            font-size: 13px;
        }
        .hidden { display: none !important; }
        
        #qr-container { text-align: center; }
        #qr-container img {
            width: 260px;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 10px;
            background: white;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <div id="toast-container"></div>

    <div class="container">
        <div class="header">
            <h2>مرحباً، <%= user.username %> 👋</h2>
            <div style="display: flex; gap: 10px;">
                <a href="/logs" class="btn btn-secondary">سجل الرسائل 📜</a>
                <a href="/logout" class="btn btn-danger">تسجيل خروج</a>
            </div>
        </div>
        
        <div class="grid">
            <div class="card" id="connection-card">
                <h3 id="status-title">حالة الاتصال ⏳</h3>
                
                <div id="qr-container" class="hidden">
                    <p style="color: var(--text-muted);">امسح رمز QR باستخدام واتساب في هاتفك لربط الجلسة:</p>
                    <div id="qr-img"></div>
                </div>
                
                <div id="connected-container" class="hidden">
                    <p style="color: var(--primary); font-size: 18px; font-weight: 700;">✅ واتساب متصل وجاهز للإرسال!</p>
                    
                    <h4 style="margin-top: 30px;">الربط الخارجي (API Token) 🔗</h4>
                    
                    <div class="token-box">
                        <input type="text" id="apiToken" value="<%= user.apiToken %>" readonly>
                        <button class="btn btn-primary" onclick="copyToken()">نسخ الرمز</button>
                    </div>
                    
                    <form method="POST" action="/refresh-token" onsubmit="return confirm('هل أنت متأكد من تغيير التوكن؟')">
                        <button type="submit" class="btn btn-secondary" style="width:100%;">توليد رمز جديد 🔄</button>
                    </form>

                    <h4 style="margin-top: 30px;">طريقة استخدام الـ API 💻</h4>
                    <pre>
{
  "to": ["966511111111"],
  "body": "مرحباً! هذه رسالة مع صورة",
  "media": [
    {
       "mimetype": "image/png",
       "filename": "image.png",
       "data": "iVBORw0KGgo..."
    }
  ]
}</pre>
                </div>
            </div>

            <div class="card hidden" id="chat-card">
                <h3>الإرسال السريع 💬</h3>
                <div class="chat-box" id="messages"></div>
                
                <input type="text" id="phone" placeholder="الأرقام (افصل بفاصلة. مثال: 9665.., 9665..)" dir="ltr">
                
                <div class="file-upload-box" onclick="document.getElementById('mediaFiles').click()">
                    📎 اضغط هنا لإرفاق الصور أو الملفات
                </div>
                <input type="file" id="mediaFiles" multiple class="hidden" onchange="updateFileName()">
                <p id="fileNames" style="color: var(--primary); font-size: 13px; font-weight: 600; margin-top:-10px;"></p>

                <textarea id="msg" placeholder="اكتب رسالتك هنا..." rows="3"></textarea>
                <button class="btn btn-primary" id="send-btn" style="width: 100%;">إرسال الرسالة 🚀</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io({ query: { userId: "<%= user._id %>" } });

        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = type === 'success' ? `✅ ${message}` : `❌ ${message}`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        socket.on('qr', (imgData) => {
            document.getElementById('status-title').innerText = "بانتظار المسح 📱";
            document.getElementById('qr-container').classList.remove('hidden');
            document.getElementById('connected-container').classList.add('hidden');
            document.getElementById('chat-card').classList.add('hidden');
            document.getElementById('qr-img').innerHTML = `<img src="${imgData}">`;
        });

        socket.on('ready', () => {
            document.getElementById('status-title').innerText = "متصل ✅";
            document.getElementById('qr-container').classList.add('hidden');
            document.getElementById('connected-container').classList.remove('hidden');
            document.getElementById('chat-card').classList.remove('hidden');
        });

        socket.on('status-update', (msg) => document.getElementById('status-title').innerText = msg);

        socket.on('message-sent', (data) => {
            const el = document.createElement('div');
            el.className = 'message';
            el.innerText = `أنت -> ${data.to}: ${data.body}`;
            const msgs = document.getElementById('messages');
            msgs.appendChild(el);
            msgs.scrollTop = msgs.scrollHeight;
        });

        function updateFileName() {
            const files = document.getElementById('mediaFiles').files;
            if(files.length > 0) {
                let totalSize = 0;
                for(let i=0; i<files.length; i++) totalSize += files[i].size;
                const sizeMB = (totalSize / (1024 * 1024)).toFixed(2);
                
                // تم تقليص الحد إلى 15 ميجا لتسريع الرفع وتخفيف الضغط عن السيرفر المجاني
                if (sizeMB > 15) {
                    document.getElementById('fileNames').innerHTML = `<span style="color:var(--danger);">❌ حجم الملفات (${sizeMB} MB) يتجاوز الحد المسموح (15 MB)</span>`;
                } else {
                    document.getElementById('fileNames').innerHTML = `تم تحديد ${files.length} مرفقات (${sizeMB} MB) جاهزة للرفع.`;
                }
            } else {
                document.getElementById('fileNames').innerText = '';
            }
        }

        function fileToBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve({
                    mimetype: file.type,
                    filename: file.name,
                    data: reader.result
                });
                reader.onerror = error => reject(error);
            });
        }

        document.getElementById('send-btn').onclick = async () => {
            const to = document.getElementById('phone').value;
            const body = document.getElementById('msg').value;
            const fileInput = document.getElementById('mediaFiles');
            const token = document.getElementById('apiToken').value; // استخدام التوكن الخاص بالمستخدم
            
            if (!to || (!body && fileInput.files.length === 0)) return showToast("الرجاء إدخال الأرقام والنص أو الملف!", "error");
            
            const MAX_SIZE_MB = 15;
            let totalSize = 0;
            for(let i = 0; i < fileInput.files.length; i++) {
                totalSize += fileInput.files[i].size;
            }
            if (totalSize > MAX_SIZE_MB * 1024 * 1024) {
                return showToast(`حجم الملف كبير جداً! الحد الأقصى هو ${MAX_SIZE_MB} ميجابايت.`, "error");
            }
            
            const btn = document.getElementById('send-btn');
            btn.innerText = 'جاري المعالجة والإرسال... ⏳';
            btn.disabled = true;

            try {
                const mediaArray = [];
                for(let i = 0; i < fileInput.files.length; i++) {
                    mediaArray.push(await fileToBase64(fileInput.files[i]));
                }

                // 🌟 الحل الجذري: إرسال الطلب عبر الـ API الرسمي بدلاً من Socket
                // الـ API أقوى بكثير في التعامل مع الملفات الكبيرة
                const response = await fetch('/api/send-message', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        to: to.split(',').map(n => n.trim()).filter(n => n),
                        body: body,
                        media: mediaArray
                    })
                });

                const result = await response.json();
                
                btn.innerText = 'إرسال الرسالة 🚀';
                btn.disabled = false;
                
                if (result.success) {
                    showToast("تم الإرسال بنجاح!", "success");
                    document.getElementById('msg').value = '';
                    fileInput.value = '';
                    document.getElementById('fileNames').innerText = '';
                    
                    // إضافة الرسالة لسجل المحادثة الوهمي في الشاشة
                    const msgs = document.getElementById('messages');
                    const el = document.createElement('div');
                    el.className = 'message';
                    el.innerText = `أنت -> ${to}: ${body || '(مرفق)'}`;
                    msgs.appendChild(el);
                    msgs.scrollTop = msgs.scrollHeight;
                } else {
                    showToast(result.error || "حدث خطأ في الإرسال لبعض الأرقام", "error");
                }
                
            } catch(e) {
                console.error(e);
                showToast("حدث خطأ أثناء الاتصال بالسيرفر! تأكد من سرعة الإنترنت.", "error");
                btn.innerText = 'إرسال الرسالة 🚀';
                btn.disabled = false;
            }
        };

        function copyToken() {
            const tokenInput = document.getElementById('apiToken');
            tokenInput.select();
            document.execCommand('copy');
            showToast('تم نسخ رمز الـ API بنجاح!');
        }
    </script>
</body>
</html>
