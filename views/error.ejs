<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خطأ <%= code %> | واتساب تكوين</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Tajawal', sans-serif; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .error-container { text-align: center; max-width: 500px; }
        .error-code { font-size: 120px; font-weight: 900; color: #cbd5e1; line-height: 1; margin-bottom: 10px; }
        .error-icon { font-size: 60px; margin-bottom: 20px; }
        .error-title { font-size: 28px; font-weight: 800; color: #1e293b; margin-bottom: 15px; }
        .error-message { font-size: 16px; color: #64748b; line-height: 1.8; margin-bottom: 30px; }
        .error-actions { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
        .btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 30px; border-radius: 10px; text-decoration: none; font-family: inherit; font-weight: 700; font-size: 15px; transition: all 0.3s; border: none; cursor: pointer; }
        .btn-primary { background: #25d366; color: white; box-shadow: 0 4px 6px rgba(37, 211, 102, 0.3); }
        .btn-primary:hover { background: #22c35e; transform: translateY(-2px); }
        .btn-secondary { background: white; color: #475569; border: 2px solid #e2e8f0; }
        .btn-secondary:hover { border-color: #94a3b8; background: #f8fafc; }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-code"><%= code %></div>
        <div class="error-icon">
            <% if (code === 404) { %>🔍<% } else if (code === 403) { %>🔒<% } else if (code === 429) { %>⏳<% } else { %>⚠️<% } %>
        </div>
        <h1 class="error-title"><%= title %></h1>
        <p class="error-message"><%= message %></p>
        <div class="error-actions">
            <a href="/" class="btn btn-primary">🏠 الصفحة الرئيسية</a>
            <a href="javascript:history.back()" class="btn btn-secondary">← رجوع</a>
        </div>
    </div>
</body>
</html>
