<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>إنشاء حساب جديد</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;800&display=swap');
        body { font-family: 'Tajawal', sans-serif; background: #f8fafc; margin: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .auth-card { background: white; padding: 40px; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center; border-top: 4px solid #3b82f6; }
        .auth-card h2 { margin-top: 0; color: #1e293b; font-weight: 800; font-size: 24px; margin-bottom: 5px; }
        .auth-card p { color: #64748b; font-size: 14px; margin-bottom: 25px; }
        .input-group { margin-bottom: 15px; text-align: right; }
        .input-group label { display: block; font-size: 14px; font-weight: bold; color: #475569; margin-bottom: 5px; }
        .input-group input { width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 15px; box-sizing: border-box; outline: none; }
        .input-group input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
        .btn { width: 100%; padding: 12px; background: #3b82f6; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; font-family: inherit; cursor: pointer; margin-top: 10px; }
        .btn:hover { background: #2563eb; }
        .error { background: #fef2f2; color: #ef4444; padding: 10px; border-radius: 8px; font-size: 14px; margin-bottom: 20px; font-weight: bold; }
        .links { margin-top: 20px; font-size: 14px; }
        .links a { color: #3b82f6; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <div class="auth-card">
        <h2>حساب جديد 🚀</h2>
        <p>انضم إلينا وابدأ حملاتك الإعلانية بسهولة</p>
        <% if (error) { %><div class="error"><%= error %></div><% } %>
        <form action="/register" method="POST">
            <div class="input-group">
                <label>اسم المستخدم (لتسجيل الدخول)</label>
                <input type="text" name="username" required>
            </div>
            <div class="input-group">
                <label>رقم الواتساب (للتفعيل)</label>
                <input type="text" name="phone" placeholder="مثال: 9665..." dir="ltr" required>
            </div>
            <div class="input-group">
                <label>كلمة المرور</label>
                <input type="password" name="password" required>
            </div>
            <button type="submit" class="btn">تسجيل وحصول على يومين مجاناً</button>
        </form>
        <div class="links">
            <a href="/login">لديك حساب بالفعل؟ تسجيل الدخول</a>
        </div>
    </div>
</body>
</html>
