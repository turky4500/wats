<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الإدارة المركزية | واتساب تكوين</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #6366f1; --primary-dark: #4f46e5; --primary-light: #eef2ff;
            --green: #10b981; --green-light: #ecfdf5;
            --blue: #3b82f6; --blue-light: #eff6ff;
            --red: #ef4444; --red-light: #fef2f2;
            --orange: #f59e0b; --orange-light: #fffbeb;
            --purple: #8b5cf6; --purple-light: #f5f3ff;
            --dark: #0f172a; --dark2: #1e293b; --gray: #64748b; --gray-light: #94a3b8;
            --bg: #f8fafc; --card: #ffffff;
            --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
            --shadow-lg: 0 10px 25px -5px rgba(0,0,0,0.08);
            --radius: 16px;
        }
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); color: var(--dark2); line-height: 1.7; }

        /* ===== Top Bar ===== */
        .topbar {
            background: linear-gradient(135deg, var(--dark) 0%, #1a1a2e 50%, var(--primary-dark) 100%);
            color: white; padding: 0 40px; display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 100; height: 65px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        }
        .topbar-brand { display: flex; align-items: center; gap: 12px; font-weight: 900; font-size: 19px; }
        .topbar-brand .crown { background: linear-gradient(135deg, #fbbf24, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 24px; }
        .topbar-actions { display: flex; gap: 10px; }
        .topbar-actions a { color: rgba(255,255,255,0.7); text-decoration: none; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 700; transition: all 0.2s; }
        .topbar-actions a:hover { background: rgba(255,255,255,0.1); color: white; }
        .topbar-actions .btn-logout { background: rgba(239,68,68,0.15); color: #fca5a5; }
        .topbar-actions .btn-logout:hover { background: rgba(239,68,68,0.3); }

        /* ===== Container ===== */
        .container { max-width: 1400px; margin: 0 auto; padding: 30px 40px; }

        /* ===== Stats Row ===== */
        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: var(--card); border-radius: var(--radius); padding: 25px; box-shadow: var(--shadow); position: relative; overflow: hidden; transition: all 0.3s; border: 1px solid transparent; }
        .stat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
        .stat-card.purple { border-bottom: 3px solid var(--purple); }
        .stat-card.green { border-bottom: 3px solid var(--green); }
        .stat-card.blue { border-bottom: 3px solid var(--blue); }
        .stat-card .stat-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 15px; }
        .stat-card .stat-label { font-size: 13px; color: var(--gray); font-weight: 600; }
        .stat-card .stat-value { font-size: 38px; font-weight: 900; color: var(--dark); line-height: 1.1; }
        .stat-card .stat-bg { position: absolute; bottom: -15px; left: -10px; font-size: 90px; opacity: 0.04; }

        /* ===== Grid ===== */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-bottom: 25px; }
        .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: 25px; margin-bottom: 25px; }

        /* ===== Card ===== */
        .card { background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); border: 1px solid #e2e8f0; overflow: hidden; }
        .card-header { padding: 20px 25px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
        .card-header h3 { font-size: 17px; font-weight: 800; display: flex; align-items: center; gap: 10px; }
        .card-body { padding: 25px; }

        /* ===== System WA Card ===== */
        .system-card { background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 100%); border: 1px solid #bbf7d0; }
        .system-card .card-header { border-color: #bbf7d0; }
        #sys-status { font-weight: 800; font-size: 15px; display: flex; align-items: center; gap: 8px; }
        #sys-qr { width: 200px; border-radius: 14px; border: 3px solid #d1fae5; padding: 8px; background: white; }
        .sys-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
        .sys-dot.on { background: var(--green); box-shadow: 0 0 0 3px rgba(16,185,129,0.2); animation: gpulse 2s infinite; }
        .sys-dot.off { background: var(--red); }
        @keyframes gpulse { 0%,100% { box-shadow: 0 0 0 3px rgba(16,185,129,0.2); } 50% { box-shadow: 0 0 0 8px rgba(16,185,129,0.05); } }


        /* ===== Settings Card ===== */
        .settings-card { border: 1px solid #e2e8f0; }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-weight: 700; font-size: 13px; color: var(--gray); margin-bottom: 6px; }
        .form-group input { width: 100%; padding: 11px 14px; border: 2px solid #e2e8f0; border-radius: 10px; font-family: inherit; font-size: 14px; outline: none; transition: border 0.2s; }
        .form-group input:focus { border-color: var(--primary); }
        .form-divider { border-top: 1px solid #f1f5f9; margin: 20px 0; }

        /* ===== Chart ===== */
        .bar-chart { display: flex; align-items: flex-end; gap: 8px; height: 150px; padding-top: 10px; border-bottom: 2px solid #f1f5f9; }
        .bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 4px; }
        .bar { width: 100%; border-radius: 6px 6px 0 0; transition: height 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); min-height: 4px; }
        .bar.gradient { background: linear-gradient(180deg, var(--primary) 0%, #818cf8 100%); }
        .bar-label { font-size: 11px; color: var(--gray-light); margin-top: 6px; }
        .bar-value { font-size: 11px; font-weight: 800; color: var(--dark2); }

        /* ===== Top Users ===== */
        .rank-list { list-style: none; }
        .rank-item { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f8fafc; }
        .rank-item:last-child { border: none; }
        .rank-info { display: flex; align-items: center; gap: 12px; }
        .rank-medal { font-size: 22px; width: 30px; text-align: center; }
        .rank-name { font-weight: 700; font-size: 14px; }
        .rank-count { background: #f1f5f9; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 800; color: var(--gray); }

        /* ===== Add User ===== */
        .add-user-form { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; }
        .add-user-form .form-group { flex: 1; min-width: 150px; margin: 0; }
        .add-user-form .form-group input { margin: 0; }

        /* ===== Table ===== */
        .table-card { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: 14px; }
        thead th { background: #f8fafc; color: var(--gray); font-weight: 700; padding: 14px 18px; text-align: right; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid #e2e8f0; }
        tbody td { padding: 16px 18px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
        tbody tr { transition: background 0.15s; }
        tbody tr:hover { background: #fafbff; }
        .user-name { font-weight: 800; color: var(--dark); font-size: 15px; }
        .user-phone { color: var(--gray); font-size: 13px; direction: ltr; }
        .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 800; }
        .badge-green { background: var(--green-light); color: #059669; }
        .badge-red { background: var(--red-light); color: #dc2626; }
        .badge-gray { background: #f1f5f9; color: var(--gray); }

        .action-btns { display: flex; gap: 6px; flex-wrap: wrap; }
        .action-btn { padding: 7px 14px; border: none; border-radius: 8px; cursor: pointer; font-family: inherit; font-weight: 700; color: white; font-size: 12px; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
        .action-btn:hover { transform: translateY(-1px); box-shadow: 0 2px 6px rgba(0,0,0,0.15); }
        .action-btn.blue { background: var(--blue); }
        .action-btn.dark { background: var(--dark2); }
        .action-btn.purple { background: var(--purple); }
        .action-btn.red { background: var(--red); }
        .action-btn.green { background: var(--green); }

        /* ===== Buttons ===== */
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 11px 22px; border: none; border-radius: 10px; font-family: inherit; font-weight: 700; font-size: 14px; cursor: pointer; text-decoration: none; transition: all 0.2s; color: white; }
        .btn:hover { transform: translateY(-1px); }
        .btn-primary { background: var(--primary); }
        .btn-blue { background: var(--blue); }
        .btn-green { background: var(--green); }
        .btn-red { background: var(--red); }
        .btn-dark { background: var(--dark2); }
        .btn-full { width: 100%; }

        /* ===== Modal ===== */
        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,0.6); backdrop-filter: blur(4px); align-items: center; justify-content: center; z-index: 1000; }
        .modal-overlay.show { display: flex; }
        .modal-box { background: white; border-radius: 20px; width: 100%; max-width: 440px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); animation: modalIn 0.3s ease; }
        @keyframes modalIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
        .modal-header { padding: 22px 25px; border-bottom: 1px solid #f1f5f9; }
        .modal-header h3 { font-size: 18px; font-weight: 900; }
        .modal-body { padding: 25px; }
        .modal-footer { padding: 15px 25px; border-top: 1px solid #f1f5f9; display: flex; gap: 10px; justify-content: flex-end; }

        /* ===== Responsive ===== */
        @media (max-width: 900px) {
            .topbar { padding: 0 20px; }
            .container { padding: 20px; }
            .grid-2, .grid-2-1 { grid-template-columns: 1fr; }
            .stats-row { grid-template-columns: repeat(2, 1fr); }
            .action-btns { flex-direction: column; }
        }
        @media (max-width: 600px) {
            .stats-row { grid-template-columns: 1fr; }
            .add-user-form { flex-direction: column; }
            .topbar-brand span:not(.crown) { display: none; }
        }
    </style>
</head>
<body>
    <!-- Top Bar -->
    <div class="topbar">
        <div class="topbar-brand">
            <span class="crown">👑</span>
            <span>الإدارة المركزية</span>
        </div>
        <div class="topbar-actions">
            <a href="/dashboard">📊 لوحتي</a>
            <a href="/logout" class="btn-logout">🚪 خروج</a>
        </div>
    </div>

    <div class="container">
        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-card purple">
                <div class="stat-bg">👥</div>
                <div class="stat-icon" style="background: var(--purple-light); color: var(--purple);">👥</div>
                <div class="stat-label">إجمالي العملاء</div>
                <div class="stat-value"><%= users.length %></div>
            </div>
            <div class="stat-card green">
                <div class="stat-bg">📨</div>
                <div class="stat-icon" style="background: var(--green-light); color: var(--green);">📨</div>
                <div class="stat-label">إجمالي الرسائل</div>
                <div class="stat-value"><%= totalSystemMessages %></div>
            </div>
            <div class="stat-card blue">
                <div class="stat-bg">✅</div>
                <div class="stat-icon" style="background: var(--blue-light); color: var(--blue);">✅</div>
                <div class="stat-label">عملاء نشطون</div>
                <div class="stat-value"><%= users.filter(u => { let d = u.subscriptionEndsAt ? Math.ceil((new Date(u.subscriptionEndsAt) - new Date()) / 86400000) : 0; return d > 0; }).length %></div>
            </div>
        </div>

        <!-- System WA + Settings -->
        <div class="grid-2">
            <div class="card system-card">
                <div class="card-header">
                    <h3>🤖 رقم الإدارة</h3>
                </div>
                <div class="card-body">
                    <div id="sys-status" style="color:#b91c1c; margin-bottom: 15px;">
                        <span class="sys-dot off"></span> بانتظار التحميل...
                    </div>

                    <!-- حالة متصل -->
                    <div id="sys-connected" style="display:none; background:var(--green-light); border-radius:12px; padding:18px; margin-bottom:15px;">
                        <div style="display:flex; align-items:center; gap:12px;">
                            <div style="width:44px;height:44px;background:var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:20px;flex-shrink:0;">✓</div>
                            <div><strong style="color:#166534;">رقم الإدارة متصل وجاهز</strong><br><span style="font-size:12px;color:#4ade80;">يعمل لإرسال أكواد التفعيل</span></div>
                        </div>
                    </div>

                    <!-- قسم الباركود -->
                    <div id="sys-link-section" style="display:none;">
                        <div id="sys-qr-container" style="text-align:center;">
                            <img id="sys-qr" src="">
                            <p style="color:var(--gray); font-size:12px; margin-top:8px;">📱 امسح الباركود من واتساب ← الأجهزة المرتبطة</p>
                        </div>
                    </div>

                    <form action="/admin/disconnect-system-whatsapp" method="POST" style="margin-top:15px;" onsubmit="return confirm('هل تريد فصل الرقم الإداري وربط رقم جديد؟');">
                        <button type="submit" class="btn btn-red btn-full">🔌 فصل وإعادة ربط</button>
                    </form>
                </div>
            </div>

            <div class="card settings-card">
                <div class="card-header">
                    <h3>⚙️ الإعدادات</h3>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/settings">
                        <div class="form-group">
                            <label>📞 رقم الدعم الفني</label>
                            <input type="text" name="supportPhone" value="<%= settings.supportPhone %>" placeholder="966598686902" required>
                        </div>
                        <div class="form-group">
                            <label>🎁 الأيام المجانية للتجربة</label>
                            <input type="number" name="freeTrialDays" value="<%= settings.freeTrialDays %>" min="0" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-full">💾 حفظ الإعدادات</button>
                    </form>

                    <div class="form-divider"></div>

                    <form method="POST" action="/admin/change-password" onsubmit="return confirm('تأكيد تغيير كلمة مرور الإدارة؟');">
                        <div class="form-group">
                            <label>🔑 كلمة مرور جديدة للإدارة</label>
                            <input type="password" name="newPassword" placeholder="أدخل كلمة المرور الجديدة" required minlength="6">
                        </div>
                        <button type="submit" class="btn btn-red btn-full">🔑 تغيير كلمة المرور</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Chart + Top Users -->
        <div class="grid-2-1">
            <div class="card">
                <div class="card-header"><h3>📈 إحصائية آخر 7 أيام</h3></div>
                <div class="card-body">
                    <% let maxCount = 0; dailyStats.forEach(s => { if(s.count > maxCount) maxCount = s.count; }); if(maxCount===0) maxCount=1; %>
                    <div class="bar-chart">
                        <% dailyStats.forEach(s => { let hp = (s.count/maxCount)*100; %>
                        <div class="bar-col">
                            <div class="bar-value"><%= s.count %></div>
                            <div class="bar gradient" style="height: <%= hp %>%;"></div>
                            <div class="bar-label"><%= s._id.split('-')[2] %>/<%= s._id.split('-')[1] %></div>
                        </div>
                        <% }) %>
                        <% if(dailyStats.length===0) { %><p style="width:100%;text-align:center;color:var(--gray-light);padding:40px 0;">لا توجد بيانات بعد</p><% } %>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-header"><h3>🏆 الأكثر إرسالاً</h3></div>
                <div class="card-body" style="padding-top: 15px;">
                    <ul class="rank-list">
                        <% topUsers.forEach((t, i) => { %>
                        <li class="rank-item">
                            <div class="rank-info">
                                <span class="rank-medal"><%= i===0?'🥇':(i===1?'🥈':(i===2?'🥉':'👤')) %></span>
                                <span class="rank-name"><%= t.username %></span>
                            </div>
                            <span class="rank-count"><%= t.count %> رسالة</span>
                        </li>
                        <% }) %>
                        <% if(topUsers.length===0) { %><li class="rank-item" style="justify-content:center;color:var(--gray-light);">لا توجد إحصائيات</li><% } %>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Add User -->
        <div class="card" style="margin-bottom: 25px;">
            <div class="card-header">
                <h3>➕ إضافة عميل جديد <span class="badge badge-green" style="font-size:11px;">+<%= settings.freeTrialDays %> أيام مجاناً</span></h3>
            </div>
            <div class="card-body">
                <form method="POST" action="/admin/add-user" class="add-user-form">
                    <div class="form-group">
                        <label>اسم المستخدم</label>
                        <input type="text" name="username" placeholder="مثال: ahmed_store" required>
                    </div>
                    <div class="form-group">
                        <label>رقم الجوال</label>
                        <input type="text" name="phone" placeholder="9665xxxxxxxx">
                    </div>
                    <div class="form-group">
                        <label>كلمة المرور</label>
                        <input type="password" name="password" placeholder="••••••" required>
                    </div>
                    <button type="submit" class="btn btn-green" style="height: 44px; margin-top: auto;">✅ إنشاء وتفعيل</button>
                </form>
            </div>
        </div>

        <!-- Users Table -->
        <div class="card table-card">
            <div class="card-header">
                <h3>👥 قائمة العملاء (<%= users.length %>)</h3>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>المستخدم</th>
                        <th>الجوال</th>
                        <th>الاشتراك</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach((u, idx) => {
                        let daysLeft = 0;
                        if(u.subscriptionEndsAt) { daysLeft = Math.ceil((new Date(u.subscriptionEndsAt) - new Date()) / 86400000); if(daysLeft<0) daysLeft=0; }
                    %>
                    <tr>
                        <td style="color:var(--gray-light); font-weight:700;"><%= idx+1 %></td>
                        <td><span class="user-name"><%= u.username %></span></td>
                        <td><span class="user-phone"><%= u.phone || '—' %></span></td>
                        <td>
                            <span class="badge <%= daysLeft>0 ? 'badge-green' : 'badge-red' %>">
                                <%= daysLeft>0 ? `${daysLeft} يوم` : 'منتهي' %>
                            </span>
                        </td>
                        <td>
                            <span class="badge <%= u.isActive ? 'badge-green' : 'badge-gray' %>">
                                <%= u.isActive ? 'مفعّل' : 'معطّل' %>
                            </span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="action-btn blue" onclick="openModal('<%= u._id %>', '<%= u.username %>')">⚙️ تعديل</button>
                                <a href="/admin/logs/<%= u._id %>" class="action-btn dark">📜 سجل</a>
                                <a href="/admin/login-as/<%= u._id %>" class="action-btn purple" onclick="return confirm('الدخول لحساب <%= u.username %>؟')">👁️ دخول</a>
                                <form action="/admin/toggle-user/<%= u._id %>" method="POST" style="display:inline;">
                                    <button type="submit" class="action-btn <%= u.isActive ? 'red' : 'green' %>" onclick="return confirm('<%= u.isActive ? 'تعطيل' : 'تفعيل' %> حساب <%= u.username %>؟')">
                                        <%= u.isActive ? '⛔' : '✅' %>
                                    </button>
                                </form>
                                <form action="/admin/delete-user/<%= u._id %>" method="POST" style="display:inline;">
                                    <button type="submit" class="action-btn red" onclick="return confirm('⚠️ حذف نهائي لحساب <%= u.username %> وجميع سجلاته؟ لا يمكن التراجع!')">🗑️</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                    <% if(users.length===0) { %>
                    <tr><td colspan="6" style="text-align:center; padding:40px; color:var(--gray-light);">لا يوجد عملاء مسجلين بعد</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="modal-overlay" onclick="if(event.target===this)this.classList.remove('show')">
        <div class="modal-box">
            <div class="modal-header">
                <h3 id="modalTitle">⚙️ تعديل العميل</h3>
            </div>
            <form id="editForm" method="POST">
                <div class="modal-body">
                    <div class="form-group">
                        <label>🔑 كلمة مرور جديدة (اتركه فارغاً لعدم التغيير)</label>
                        <input type="text" name="password" placeholder="كلمة المرور الجديدة">
                    </div>
                    <div class="form-group">
                        <label>📅 إضافة أيام للاشتراك</label>
                        <input type="number" name="addDays" placeholder="مثال: 30" min="0">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-dark" onclick="document.getElementById('editModal').classList.remove('show')">إلغاء</button>
                    <button type="submit" class="btn btn-green">💾 حفظ التعديلات</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        function openModal(id, username) {
            document.getElementById('modalTitle').innerText = '⚙️ تعديل: ' + username;
            document.getElementById('editForm').action = '/admin/edit-user/' + id;
            document.getElementById('editModal').classList.add('show');
        }

        // ===== حالات الاتصال =====
        var isAdminConnected = false;
        var sysSocket = io({ query: { userId: "111111111111111111111111" } });

        function showAdminConnected() {
            isAdminConnected = true;
            document.getElementById('sys-connected').style.display = 'block';
            document.getElementById('sys-link-section').style.display = 'none';
            document.getElementById('sys-status').innerHTML = '<span class="sys-dot on"></span> متصل وجاهز ✅';
            document.getElementById('sys-status').style.color = '#059669';
        }

        function showAdminLinkSection() {
            document.getElementById('sys-connected').style.display = 'none';
            document.getElementById('sys-link-section').style.display = 'block';
        }

        sysSocket.on('qr', function(imgData) {
            if (isAdminConnected) return;
            document.getElementById('sys-qr').src = imgData;
            showAdminLinkSection();
            document.getElementById('sys-status').innerHTML = '<span class="sys-dot off" style="background:#f59e0b;"></span> بانتظار الربط 📱';
            document.getElementById('sys-status').style.color = '#d97706';
        });

        sysSocket.on('ready', function() { showAdminConnected(); });

        sysSocket.on('reconnecting', function(msg) {
            isAdminConnected = false;
            document.getElementById('sys-connected').style.display = 'none';
            document.getElementById('sys-link-section').style.display = 'none';
            document.getElementById('sys-status').innerHTML = '<span class="sys-dot off" style="background:#f59e0b;"></span> 🔄 ' + msg;
            document.getElementById('sys-status').style.color = '#d97706';
        });

        sysSocket.on('disconnected', function(msg) {
            isAdminConnected = false;
            document.getElementById('sys-connected').style.display = 'none';
            document.getElementById('sys-status').innerHTML = '<span class="sys-dot off"></span> ❌ ' + msg;
            document.getElementById('sys-status').style.color = '#dc2626';
        });

        sysSocket.on('disconnect', function() {
            document.getElementById('sys-status').innerHTML = '<span class="sys-dot off"></span> ⚠️ انقطع الاتصال بالخادم';
            document.getElementById('sys-status').style.color = '#dc2626';
        });

        sysSocket.on('connect', function() {
            setTimeout(function() {
                if (!isAdminConnected && document.getElementById('sys-status').textContent.indexOf('بانتظار التحميل') !== -1) {
                    document.getElementById('sys-status').innerHTML = '<span class="sys-dot off"></span> غير متصل - اربط الرقم';
                    document.getElementById('sys-status').style.color = '#dc2626';
                    showAdminLinkSection();
                }
            }, 4000);
        });
    </script>
</body>
</html>
